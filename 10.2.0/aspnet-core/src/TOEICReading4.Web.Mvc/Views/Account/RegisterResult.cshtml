@model TOEICReading4.Web.Models.Account.RegisterResultViewModel
@{
    ViewBag.Title = L("SuccessfullyRegistered");
}

<div class="account-form-head">
    <h2>@L("SuccessfullyRegistered")</h2>
</div>

<div class="auth-card">
    <ul class="account-summary">
        <li><span>@L("NameSurname")</span><strong>@Model.NameAndSurname</strong></li>
        <li><span>@L("TenancyName")</span><strong>@Model.TenancyName</strong></li>
        <li><span>@L("UserName")</span><strong>@Model.UserName</strong></li>
        <li><span>@L("EmailAddress")</span><strong>@Model.EmailAddress</strong></li>
    </ul>

    @if (!Model.IsActive)
    {
        <div class="alert alert-warning" role="alert">
            @L("WaitingForActivationMessage")
        </div>
    }

    @if (Model.IsEmailConfirmationRequiredForLogin && !Model.IsEmailConfirmed)
    {
        <div class="alert alert-warning" role="alert">
            @L("WaitingForEmailActivation")
        </div>
    }

    <div class="auth-actions">
        <a asp-action="Login" class="btn btn-primary">@L("LogIn")</a>
    </div>
</div>
