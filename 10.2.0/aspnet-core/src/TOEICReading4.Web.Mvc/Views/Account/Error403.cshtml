@{
    ViewBag.Title = L("403PageHeader");
    ViewBag.HideTenantChange = true;
}

@section styles
{
    <link href="~/view-resources/Views/Account/Error403.css" rel="stylesheet" asp-append-version="true" />
}

<div class="account-form-head">
    <h2>@L("403PageHeader")</h2>
    <p>@L("403PageDescription")</p>
</div>

<div class="auth-card forbidden-box d-flex flex-column align-items-center justify-content-center text-center">
    <div class="display-1 text-warning mb-3">403</div>
    <a href="@Url.Action("Index", "Home")" class="btn btn-primary">@L("403PageButton")</a>
</div>
