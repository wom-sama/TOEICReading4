@using Abp.Authorization.Users
@model TOEICReading4.Web.Models.Account.LoginFormViewModel
@{
    ViewBag.Title = L("LogIn");
    Layout = "_Layout";
}

<div class="account-form-head">
    <h2>@L("LogIn")</h2>
    <p>@L("PleaseEnterLoginInformation")</p>
</div>

<div class="auth-card">
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @ViewBag.ErrorMessage
        </div>
    }

    @Html.ValidationSummary(true)

    <form id="LoginForm" asp-action="Login" method="post" novalidate class="auth-form">
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
        <input type="hidden" id="ReturnUrlHash" name="returnUrlHash" />

        <div class="auth-field">
            <label>@L("UserNameOrEmail")</label>
            <input asp-for="UsernameOrEmailAddress" class="form-control" placeholder="@L("UserNameOrEmail")" required autofocus maxlength="@AbpUserBase.MaxEmailAddressLength" autocomplete="username">
        </div>

        <div class="auth-field">
            <label>@L("Password")</label>
            <input type="password" class="form-control" name="Password" placeholder="@L("Password")" required maxlength="@AbpUserBase.MaxPlainPasswordLength" autocomplete="current-password">
        </div>

        <div class="auth-check">
            <div class="form-check">
                <input asp-for="RememberMe" class="form-check-input" value="true">
                <label class="form-check-label" for="RememberMe">@L("RememberMe")</label>
            </div>
        </div>

        <button type="submit" class="btn btn-primary auth-primary">
            @L("LogIn")
        </button>
    </form>
</div>

@if (Model.IsSelfRegistrationAllowed)
{
    <div class="account-switch">
        <span>@L("DontHaveAnAccount")</span>
        <a asp-action="Register">@L("Register")</a>
    </div>
}
