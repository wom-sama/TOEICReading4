@using TOEICReading4.Web.Models.Home
@using TOEICReading4.Web.Startup
@model HomeDashboardViewModel
@{
    ViewBag.Title = L("DashboardPage");
    ViewBag.CurrentPageName = PageNames.Dashboard;
}

@section Styles {
    <style>
        .dashboard-page .app-hero {
            background: linear-gradient(135deg, #ff9ac8 0%, #ffbddc 52%, #ffe9f3 100%);
        }

        .dashboard-section {
            display: grid;
            gap: 1rem;
        }

        .recent-grid,
        .quick-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1rem;
        }

        .recent-card,
        .quick-link {
            border-radius: 24px;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.84);
            border: 1px solid rgba(255, 214, 232, 0.95);
            box-shadow: var(--shadow-soft);
        }

        .recent-card-header {
            padding: 1rem 1.1rem;
            color: #fff;
            background: linear-gradient(135deg, var(--rose-500), #ff95c6);
        }

        .recent-card-header.completed {
            background: linear-gradient(135deg, #ff8dbd, #d96aa1);
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.38rem 0.72rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.18);
            font-size: 0.78rem;
            font-weight: 800;
            margin-bottom: 0.8rem;
        }

        .recent-card-body {
            padding: 1.1rem;
            display: flex;
            flex-direction: column;
            gap: 0.9rem;
        }

        .recent-card h3 {
            margin: 0;
            font-size: 1.1rem;
        }

        .meta-row {
            display: flex;
            justify-content: space-between;
            gap: 0.75rem;
            flex-wrap: wrap;
            color: var(--text-600);
            font-weight: 700;
        }

        .summary-box {
            padding: 0.95rem;
            border-radius: 18px;
            background: rgba(255, 248, 251, 0.82);
            border: 1px solid rgba(255, 220, 234, 0.95);
        }

        .card-actions {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .card-actions a {
            flex: 1;
            min-width: 140px;
            text-align: center;
            text-decoration: none;
            padding: 0.78rem 1rem;
            border-radius: 16px;
            font-weight: 800;
        }

        .btn-preview {
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(255, 188, 214, 0.58);
            color: var(--text-700);
        }

        .btn-primary-action,
        .btn-success-action {
            color: #fff;
            background: linear-gradient(135deg, var(--rose-500), #ff95c6);
        }

        .quick-link {
            display: block;
            padding: 1.2rem;
            text-decoration: none;
            color: var(--text-900);
        }

        .quick-link strong {
            display: block;
            margin: 0.8rem 0 0.25rem;
            font-size: 1.05rem;
        }

        .quick-link p {
            margin: 0;
            color: var(--text-600);
            font-weight: 700;
        }
    </style>
}

<div class="app-page dashboard-page">
    <section class="app-hero">
        <div class="app-hero-content">
            <div>
                <div class="app-hero-badges">
                    <span class="app-chip"><i class="fas fa-heart"></i>@L("DashboardPage")</span>
                </div>
                <h1>@L("DashboardPage")</h1>
                <p>@L("DashboardDescription")</p>
            </div>

            <div class="app-actions">
                <a href="/Home/Index" class="btn btn-primary">
                    <i class="fas fa-cloud-upload-alt me-2"></i>@L("UploadExam")
                </a>
                <a href="/Exam/List" class="btn btn-secondary">
                    <i class="fas fa-book-open me-2"></i>@L("ExamLibrary")
                </a>
            </div>
        </div>
    </section>

    <div class="app-stat-grid">
        <div class="app-stat-card">
            <div class="app-stat-icon"><i class="fas fa-book-open"></i></div>
            <div>
                <strong>@Model.TotalExams</strong>
                <span>@L("TotalExamsCreated")</span>
            </div>
        </div>
        <div class="app-stat-card">
            <div class="app-stat-icon"><i class="fas fa-check-circle"></i></div>
            <div>
                <strong>@Model.CompletedExams</strong>
                <span>@L("ExamsCompleted")</span>
            </div>
        </div>
        <div class="app-stat-card">
            <div class="app-stat-icon"><i class="fas fa-flag"></i></div>
            <div>
                <strong>@Model.AvailableExams</strong>
                <span>@L("AvailableExamsLabel")</span>
            </div>
        </div>
        <div class="app-stat-card">
            <div class="app-stat-icon"><i class="fas fa-award"></i></div>
            <div>
                <strong>@Model.BestScore</strong>
                <span>@L("BestScoreLabel")</span>
            </div>
        </div>
    </div>

    <section class="app-panel dashboard-section">
        <div class="app-panel-header">
            <div>
                <h2>@L("RecentActivityTitle")</h2>
            </div>
        </div>

        @if (Model.RecentExams == null || Model.RecentExams.Count == 0)
        {
            <div class="app-empty-state">
                <i class="fas fa-inbox"></i>
                <h3>@L("NoExamsYetTitle")</h3>
                <p>@L("NoRecentActivityDescription")</p>
                <a href="/Home/Index" class="btn btn-primary mt-3">
                    <i class="fas fa-upload me-2"></i>@L("UploadExam")
                </a>
            </div>
        }
        else
        {
            <div class="recent-grid">
                @foreach (var item in Model.RecentExams)
                {
                    <div class="recent-card">
                        <div class="recent-card-header @(item.HasAttempt ? "completed" : string.Empty)">
                            <span class="status-pill">
                                <i class="fas @(item.HasAttempt ? "fa-check-circle" : "fa-star")"></i>
                                @(item.HasAttempt ? L("CompletedStatus") : L("NewStatus"))
                            </span>
                            <h3>@item.Title</h3>
                        </div>
                        <div class="recent-card-body">
                            <div class="meta-row">
                                <span><i class="far fa-calendar me-1"></i>@item.ActivityDate.ToString("dd/MM/yyyy HH:mm")</span>
                                <span><i class="far fa-clock me-1"></i>@item.DurationMinutes @L("MinutesShort")</span>
                            </div>

                            <div class="summary-box">
                                <div><strong>@L("QuestionCountLabel"):</strong> @item.QuestionCount</div>
                                @if (item.HasAttempt)
                                {
                                    <div class="mt-2"><strong>@L("LatestResultLabel"):</strong> @(item.LatestScore ?? 0)/495</div>
                                }
                                else
                                {
                                    <div class="mt-2 text-muted">@L("ReadyToStartDescription")</div>
                                }
                            </div>

                            <div class="card-actions">
                                <a class="btn-preview" href="/Exam/Preview/@item.ExamId">
                                    <i class="fas fa-eye me-2"></i>@L("PreviewExam")
                                </a>
                                @if (item.HasAttempt && item.LatestAttemptId.HasValue)
                                {
                                    <a class="btn-success-action" href="/Exam/Result/@item.LatestAttemptId.Value">
                                        <i class="fas fa-chart-bar me-2"></i>@L("ViewResult")
                                    </a>
                                }
                                else
                                {
                                    <a class="btn-primary-action" href="/Exam/Start/@item.ExamId">
                                        <i class="fas fa-play me-2"></i>@L("StartExam")
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section class="app-panel">
        <div class="app-panel-header">
            <div>
                <h2>@L("QuickActionsTitle")</h2>
            </div>
        </div>

        <div class="quick-actions">
            <a href="/Home/Index" class="quick-link">
                <i class="fas fa-cloud-upload-alt fa-lg"></i>
                <strong>@L("UploadNewExamAction")</strong>
                <p>@L("UploadExamDescription")</p>
            </a>
            <a href="/Exam/List" class="quick-link">
                <i class="fas fa-book-open fa-lg"></i>
                <strong>@L("BrowseExamLibraryAction")</strong>
                <p>@L("ExamLibraryDescription")</p>
            </a>
        </div>
    </section>
</div>
