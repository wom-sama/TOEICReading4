@using TOEICReading4.Web.Models.Home
@using TOEICReading4.Web.Startup
@model HomeDashboardViewModel
@{
    ViewBag.Title = L("DashboardPage");
    ViewBag.CurrentPageName = PageNames.Home;
}

@section Styles {
    <style>
        :root {
            --primary: #2563eb;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --surface: #ffffff;
            --surface-alt: #f8fafc;
            --text: #111827;
            --muted: #64748b;
            --border: #dbe3ef;
            --shadow: 0 18px 42px rgba(15, 23, 42, 0.08);
        }

        .dashboard-shell {
            padding: 2rem 0 3rem;
        }

        .dashboard-hero {
            border-radius: 24px;
            padding: 2.25rem 2rem;
            color: #fff;
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 60%, #2563eb 100%);
            box-shadow: var(--shadow);
            margin-bottom: 1.5rem;
        }

        .dashboard-hero h1 {
            margin: 0 0 8px;
            font-weight: 700;
        }

        .dashboard-hero p {
            margin: 0;
            color: rgba(255, 255, 255, 0.82);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .stat-card {
            display: flex;
            gap: 16px;
            align-items: center;
            padding: 1.2rem;
            border-radius: 22px;
            background: var(--surface);
            border: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: var(--shadow);
        }

        .stat-icon {
            width: 58px;
            height: 58px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.35rem;
            flex-shrink: 0;
        }

        .stat-icon.primary {
            background: rgba(37, 99, 235, 0.12);
            color: var(--primary);
        }

        .stat-icon.success {
            background: rgba(16, 185, 129, 0.12);
            color: var(--success);
        }

        .stat-icon.warning {
            background: rgba(245, 158, 11, 0.14);
            color: var(--warning);
        }

        .stat-icon.danger {
            background: rgba(239, 68, 68, 0.12);
            color: var(--danger);
        }

        .stat-card .value {
            display: block;
            font-size: 1.85rem;
            line-height: 1;
            font-weight: 700;
            color: var(--text);
        }

        .stat-card .label {
            display: block;
            margin-top: 6px;
            color: var(--muted);
            font-weight: 600;
        }

        .section-card {
            border-radius: 22px;
            background: var(--surface);
            border: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: var(--shadow);
            padding: 1.4rem;
            margin-bottom: 1.5rem;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0 0 1rem;
            font-size: 1.15rem;
            font-weight: 700;
        }

        .recent-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1rem;
        }

        .recent-card {
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid rgba(148, 163, 184, 0.18);
            background: var(--surface-alt);
        }

        .recent-card-header {
            padding: 1rem 1rem 0.9rem;
            color: #fff;
            background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
        }

        .recent-card-header.completed {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.36rem 0.72rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.16);
            font-size: 0.78rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .recent-card-header h3 {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 700;
        }

        .recent-card-body {
            padding: 1rem;
        }

        .meta-row {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            color: var(--muted);
            font-size: 0.88rem;
            margin-bottom: 0.9rem;
        }

        .summary-box {
            padding: 0.9rem;
            border-radius: 16px;
            border: 1px solid var(--border);
            background: #fff;
            margin-bottom: 0.9rem;
        }

        .summary-box strong {
            color: var(--text);
        }

        .card-actions {
            display: flex;
            gap: 10px;
        }

        .card-actions a {
            flex: 1;
            border-radius: 14px;
            padding: 0.75rem 0.9rem;
            font-weight: 700;
            text-align: center;
            text-decoration: none;
        }

        .btn-preview {
            color: var(--text);
            background: #fff;
            border: 1px solid rgba(148, 163, 184, 0.28);
        }

        .btn-primary-action {
            color: #fff;
            background: linear-gradient(135deg, var(--primary) 0%, #1d4ed8 100%);
        }

        .btn-success-action {
            color: #fff;
            background: linear-gradient(135deg, var(--success) 0%, #059669 100%);
        }

        .quick-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1rem;
        }

        .quick-link {
            display: block;
            border-radius: 20px;
            padding: 1.2rem;
            text-decoration: none;
            background: linear-gradient(135deg, #eff6ff 0%, #ffffff 100%);
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
            color: var(--text);
        }

        .quick-link strong {
            display: block;
            margin-top: 0.65rem;
            margin-bottom: 0.35rem;
            font-size: 1rem;
        }

        .quick-link p {
            margin: 0;
            color: var(--muted);
        }

        .empty-state {
            text-align: center;
            padding: 2.5rem 1rem;
        }

        .empty-state i {
            font-size: 3rem;
            color: #cbd5e1;
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            color: var(--muted);
            margin-bottom: 1.2rem;
        }

        @@media (max-width: 576px) {
            .dashboard-hero,
            .section-card {
                padding-left: 1.1rem;
                padding-right: 1.1rem;
            }

            .meta-row,
            .card-actions {
                flex-direction: column;
            }
        }
    </style>
}

<div class="container-fluid px-3 px-md-4 dashboard-shell">
    <div class="dashboard-hero">
        <h1><i class="fas fa-chart-line me-2"></i>@L("DashboardPage")</h1>
        <p>@L("DashboardDescription")</p>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon primary">
                <i class="fas fa-book-open"></i>
            </div>
            <div>
                <span class="value">@Model.TotalExams</span>
                <span class="label">@L("TotalExamsCreated")</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon success">
                <i class="fas fa-check-circle"></i>
            </div>
            <div>
                <span class="value">@Model.CompletedExams</span>
                <span class="label">@L("ExamsCompleted")</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon warning">
                <i class="fas fa-flag"></i>
            </div>
            <div>
                <span class="value">@Model.AvailableExams</span>
                <span class="label">@L("AvailableExamsLabel")</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon danger">
                <i class="fas fa-trophy"></i>
            </div>
            <div>
                <span class="value">@Model.BestScore</span>
                <span class="label">@L("BestScoreLabel")</span>
            </div>
        </div>
    </div>

    <div class="section-card">
        <h2 class="section-title">
            <i class="fas fa-list-check text-primary"></i>
            <span>@L("RecentActivityTitle")</span>
        </h2>

        @if (Model.RecentExams == null || Model.RecentExams.Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <h3>@L("NoExamsYetTitle")</h3>
                <p>@L("NoRecentActivityDescription")</p>
                <a href="/Home/Index" class="btn btn-primary">
                    <i class="fas fa-upload me-2"></i>@L("UploadExam")
                </a>
            </div>
        }
        else
        {
            <div class="recent-grid">
                @foreach (var item in Model.RecentExams)
                {
                    <div class="recent-card">
                        <div class="recent-card-header @(item.HasAttempt ? "completed" : string.Empty)">
                            <span class="status-pill">
                                <i class="fas @(item.HasAttempt ? "fa-circle-check" : "fa-sparkles")"></i>
                                @(item.HasAttempt ? L("CompletedStatus") : L("NewStatus"))
                            </span>
                            <h3>@item.Title</h3>
                        </div>
                        <div class="recent-card-body">
                            <div class="meta-row">
                                <span><i class="far fa-calendar me-1"></i>@item.ActivityDate.ToString("dd/MM/yyyy HH:mm")</span>
                                <span><i class="far fa-clock me-1"></i>@item.DurationMinutes @L("MinutesShort")</span>
                            </div>

                            <div class="summary-box">
                                <div><strong>@L("QuestionCountLabel"):</strong> @item.QuestionCount</div>
                                @if (item.HasAttempt)
                                {
                                    <div class="mt-2"><strong>@L("LatestResultLabel"):</strong> @(item.LatestScore ?? 0)/495</div>
                                }
                                else
                                {
                                    <div class="mt-2 text-muted">@L("ReadyToStartDescription")</div>
                                }
                            </div>

                            <div class="card-actions">
                                <a class="btn-preview" href="/Exam/Preview/@item.ExamId">
                                    <i class="fas fa-eye me-2"></i>@L("PreviewExam")
                                </a>
                                @if (item.HasAttempt && item.LatestAttemptId.HasValue)
                                {
                                    <a class="btn-success-action" href="/Exam/Result/@item.LatestAttemptId.Value">
                                        <i class="fas fa-chart-column me-2"></i>@L("ViewResult")
                                    </a>
                                }
                                else
                                {
                                    <a class="btn-primary-action" href="/Exam/Start/@item.ExamId">
                                        <i class="fas fa-play me-2"></i>@L("StartExam")
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="section-card">
        <h2 class="section-title">
            <i class="fas fa-bolt text-primary"></i>
            <span>@L("QuickActionsTitle")</span>
        </h2>

        <div class="quick-actions">
            <a href="/Home/Index" class="quick-link">
                <i class="fas fa-cloud-upload-alt fa-lg text-primary"></i>
                <strong>@L("UploadNewExamAction")</strong>
                <p>@L("UploadExamDescription")</p>
            </a>
            <a href="/Exam/List" class="quick-link">
                <i class="fas fa-book-open fa-lg text-primary"></i>
                <strong>@L("BrowseExamLibraryAction")</strong>
                <p>@L("ExamLibraryDescription")</p>
            </a>
        </div>
    </div>
</div>
