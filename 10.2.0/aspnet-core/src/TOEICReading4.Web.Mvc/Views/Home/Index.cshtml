@using TOEICReading4.Web.Startup
@{
    ViewBag.Title = L("UploadExam");
    ViewBag.CurrentPageName = PageNames.UploadExam;
}

@section Styles {
    <style>
        .upload-page {
            gap: 1.4rem;
        }

        .upload-layout {
            display: grid;
            grid-template-columns: 320px minmax(0, 1fr);
            gap: 1rem;
            align-items: start;
        }

        .guide-list {
            list-style: none;
            margin: 0;
            padding: 0;
            display: grid;
            gap: 0.85rem;
        }

        .guide-list li {
            display: flex;
            gap: 0.7rem;
            align-items: start;
            padding: 0.95rem 1rem;
            border-radius: 20px;
            background: rgba(255, 247, 251, 0.82);
            border: 1px solid rgba(255, 218, 233, 0.95);
            color: var(--text-700);
            font-weight: 700;
        }

        .guide-list i {
            color: var(--rose-600);
            margin-top: 0.15rem;
        }

        .guide-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 1rem;
            text-decoration: none;
        }

        .upload-form-shell {
            display: grid;
            gap: 1rem;
        }

        .upload-form-grid {
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 1rem;
        }

        .upload-section-title {
            margin: 0 0 0.25rem;
            font-size: 1.25rem;
            color: var(--text-900);
        }

        .upload-section-copy {
            margin: 0 0 1rem;
            color: var(--text-600);
            font-weight: 700;
        }

        .field-label {
            display: block;
            margin-bottom: 0.45rem;
            font-weight: 800;
        }

        .required {
            color: #ff4f8c;
        }

        .upload-dropzone {
            border: 2px dashed rgba(255, 113, 173, 0.45);
            border-radius: 28px;
            background: linear-gradient(135deg, #fff8fc 0%, #fff0f7 100%);
            padding: 2.5rem 1.4rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .upload-dropzone:hover,
        .upload-dropzone.dragover {
            transform: translateY(-2px);
            border-color: var(--rose-500);
            box-shadow: 0 22px 42px rgba(217, 111, 159, 0.16);
        }

        .upload-dropzone input[type="file"] {
            display: none;
        }

        .upload-icon {
            width: 74px;
            height: 74px;
            margin: 0 auto 1rem;
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--rose-500), #ff9dc9);
            color: #fff;
            font-size: 2rem;
            box-shadow: 0 18px 30px rgba(255, 108, 171, 0.22);
        }

        .upload-title {
            font-size: 1.08rem;
            font-weight: 800;
            color: var(--text-900);
            margin-bottom: 0.35rem;
        }

        .upload-hint {
            color: var(--text-600);
            margin: 0;
            font-weight: 700;
        }

        .selected-file {
            display: none;
            margin-top: 1rem;
            color: var(--rose-700);
            font-weight: 800;
        }

        .upload-actions {
            justify-content: flex-end;
        }

        @@media (max-width: 1100px) {
            .upload-layout,
            .upload-form-grid {
                grid-template-columns: 1fr;
            }
        }

    </style>
}

<div class="app-page upload-page">
    <section class="app-hero">
        <div class="app-hero-content">
            <div>
                <div class="app-hero-badges">
                    <span class="app-chip"><i class="fas fa-file-word"></i>.docx</span>
                    <span class="app-chip"><i class="fas fa-book-open"></i>@L("ToeicReadingCategory")</span>
                    <span class="app-chip"><i class="fas fa-feather-alt"></i>@L("SpaceStudy")</span>
                </div>
                <h1>@L("UploadExam")</h1>
                <p>@L("UploadExamDescription")</p>
            </div>
        </div>
    </section>

    <div class="upload-layout">
        <aside class="app-panel">
            <div class="app-panel-header">
                <div>
                    <h2>@L("QuickGuide")</h2>
                </div>
            </div>

            <ul class="guide-list">
                <li><i class="fas fa-check-circle"></i><span>@L("UploadInfoFileRequirement")</span></li>
                <li><i class="fas fa-tags"></i><span>@L("UploadInfoTagUsage")</span></li>
                <li><i class="fas fa-layer-group"></i><span>@L("UploadInfoSupportedParts")</span></li>
            </ul>

            <a class="btn btn-secondary guide-link" href="/Template/Toeic_Template.docx">
                <i class="fas fa-download"></i>@L("DownloadTemplate")
            </a>
        </aside>

        <form id="frmUploadExam" enctype="multipart/form-data" class="upload-form-shell">
            <div class="upload-form-grid">
                <section class="app-panel">
                    <div class="app-panel-header">
                        <div>
                            <h2 class="upload-section-title">@L("GeneralInfoSection")</h2>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-8 mb-3">
                            <label class="field-label">@L("ExamTitle") <span class="required">*</span></label>
                            <input type="text" class="form-control" name="examTitle" placeholder="@L("ExamTitlePlaceholder")" required />
                        </div>
                        <div class="col-lg-4 mb-3">
                            <label class="field-label">@L("DurationLabel") <span class="required">*</span></label>
                            <input type="number" class="form-control" name="duration" value="75" min="30" max="180" required />
                        </div>
                        <div class="col-12">
                            <label class="field-label">@L("Description")</label>
                            <textarea class="form-control" name="description" rows="4" placeholder="@L("ShortDescriptionPlaceholder")"></textarea>
                        </div>
                    </div>
                </section>

                <section class="app-panel">
                    <div class="app-panel-header">
                        <div>
                            <h2 class="upload-section-title">@L("InputDataSection")</h2>
                        </div>
                    </div>

                    <label class="upload-dropzone" for="fileInput">
                        <div class="upload-icon">
                            <i class="fas fa-cloud-upload-alt"></i>
                        </div>
                        <div class="upload-title" id="uploadLabel">@L("UploadBoxLabel")</div>
                        <p class="upload-hint">@L("UploadBoxHint")</p>
                        <div class="selected-file" id="fileNameDisplay">
                            <i class="fas fa-check-circle me-2"></i><span id="selectedFileName"></span>
                        </div>
                        <input type="file" id="fileInput" name="examFile" accept=".docx" required />
                    </label>
                </section>
            </div>

            <section class="app-panel">
                <div class="app-actions upload-actions">
                    <a href="/Home/Dashboard" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>@L("DashboardPage")
                    </a>
                    <button type="submit" class="btn btn-primary" id="btnSubmit">
                        <i class="fas fa-cloud-upload-alt me-2"></i>@L("UploadExam")
                    </button>
                </div>
            </section>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            function updateSelectedFile(file) {
                if (file) {
                    $('#selectedFileName').text(file.name);
                    $('#fileNameDisplay').show();
                    $('#uploadLabel').text('@L("UploadSelectedFile")');
                } else {
                    $('#fileNameDisplay').hide();
                    $('#uploadLabel').text('@L("UploadBoxLabel")');
                }
            }

            $('#fileInput').on('change', function () {
                var file = this.files && this.files.length ? this.files[0] : null;
                updateSelectedFile(file);
            });

            $('.upload-dropzone').on('dragover', function (e) {
                e.preventDefault();
                $(this).addClass('dragover');
            });

            $('.upload-dropzone').on('dragleave', function () {
                $(this).removeClass('dragover');
            });

            $('.upload-dropzone').on('drop', function (e) {
                e.preventDefault();
                $(this).removeClass('dragover');

                var files = e.originalEvent.dataTransfer.files;
                if (files.length > 0) {
                    $('#fileInput')[0].files = files;
                    updateSelectedFile(files[0]);
                }
            });

            $('#frmUploadExam').on('submit', function (e) {
                e.preventDefault();

                var formData = new FormData(this);
                $('#btnSubmit')
                    .prop('disabled', true)
                    .html('<i class="fas fa-spinner fa-spin me-2"></i>@L("UploadProcessing")');

                $.ajax({
                    url: '/Exam/UploadAndParse',
                    type: 'POST',
                    headers: {
                        'X-XSRF-TOKEN': abp.security.antiForgery.getToken()
                    },
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        var data = response.result ? response.result : response;

                        abp.message.success('@L("UploadSuccess")', '@L("SavedSuccessfully")').done(function () {
                            if (data.examId) {
                                window.location.href = '/Exam/Preview/' + data.examId;
                            }
                        });
                    },
                    error: function (err) {
                        var errorMessage = '@L("UploadGenericError")';

                        try {
                            var responseJson = JSON.parse(err.responseText);
                            errorMessage = responseJson.result || responseJson.error?.message || err.responseText || errorMessage;
                        } catch (parseError) {
                            errorMessage = err.responseText || errorMessage;
                        }

                        abp.message.error(errorMessage, '@L("UploadFormatError")');
                    },
                    complete: function () {
                        $('#btnSubmit')
                            .prop('disabled', false)
                            .html('<i class="fas fa-cloud-upload-alt me-2"></i>@L("UploadExam")');
                    }
                });
            });
        });
    </script>
}
