@using System.Globalization
@model TOEICReading4.Web.Models.Exam.ExamResultViewModel
@{
    Layout = null;

    int minutes = Model.TimeTakenSeconds / 60;
    int seconds = Model.TimeTakenSeconds % 60;
    string timeFormatted = $"{minutes:00}:{seconds:00}";

    var partResults = new[]
    {
        new { Key = "Part5", Label = L("Part5ResultTitle"), Color = "var(--success)", Result = Model.Part5 },
        new { Key = "Part6", Label = L("Part6ResultTitle"), Color = "var(--primary)", Result = Model.Part6 },
        new { Key = "Part7", Label = L("Part7ResultTitle"), Color = "var(--warning)", Result = Model.Part7 }
    };

    var weakestPart = partResults.OrderBy(p => p.Result.Percentage).First();
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@L("ExamResultPageTitle", Model.ExamTitle)</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --primary: #2563eb;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --surface: #ffffff;
            --surface-alt: #f8fafc;
            --border: #d9e4f2;
            --text: #111827;
            --muted: #64748b;
            --shadow: 0 24px 50px rgba(15, 23, 42, 0.12);
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background:
                radial-gradient(circle at top left, rgba(37, 99, 235, 0.16), transparent 26%),
                linear-gradient(180deg, #eff6ff 0%, #eef2ff 45%, #f8fafc 100%);
            color: var(--text);
            padding: 24px 16px;
        }

        .result-shell {
            max-width: 980px;
            margin: 0 auto;
        }

        .result-card {
            background: var(--surface);
            border: 1px solid rgba(148, 163, 184, 0.2);
            border-radius: 28px;
            overflow: hidden;
            box-shadow: var(--shadow);
        }

        .hero {
            padding: 34px 28px 82px;
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 62%, #2563eb 100%);
            color: #fff;
            text-align: center;
        }

        .hero h1 {
            margin: 0 0 8px;
            font-size: 1.9rem;
            font-weight: 700;
        }

        .hero p {
            margin: 0;
            color: rgba(255, 255, 255, 0.82);
        }

        .score-panel {
            margin: -54px auto 26px;
            width: min(420px, calc(100% - 32px));
            background: var(--surface);
            border-radius: 24px;
            box-shadow: 0 22px 44px rgba(15, 23, 42, 0.15);
            border: 1px solid rgba(148, 163, 184, 0.22);
            padding: 24px;
            text-align: center;
            position: relative;
            z-index: 2;
        }

        .score-title {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--muted);
            font-weight: 700;
            margin-bottom: 12px;
        }

        .score-value {
            font-size: 4.2rem;
            line-height: 1;
            font-weight: 800;
            color: var(--primary);
        }

        .score-total {
            margin-top: 10px;
            color: var(--muted);
            font-size: 1.1rem;
            font-weight: 600;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 16px;
            padding: 0 26px 26px;
        }

        .stat-item {
            background: var(--surface-alt);
            border: 1px solid var(--border);
            border-radius: 22px;
            padding: 18px;
            text-align: center;
        }

        .stat-item i {
            font-size: 1.4rem;
            margin-bottom: 10px;
        }

        .stat-item .value {
            display: block;
            font-size: 1.85rem;
            font-weight: 700;
            line-height: 1;
            margin-bottom: 8px;
        }

        .stat-item .label {
            color: var(--muted);
            font-weight: 600;
            font-size: 0.88rem;
        }

        .analysis-section {
            padding: 0 26px 26px;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
            font-size: 1.2rem;
            font-weight: 700;
        }

        .part-card {
            background: var(--surface-alt);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 18px;
            margin-bottom: 14px;
        }

        .part-header {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 12px;
            font-weight: 700;
        }

        .part-progress {
            height: 10px;
            background: #e2e8f0;
            border-radius: 999px;
            overflow: hidden;
        }

        .part-progress > span {
            display: block;
            height: 100%;
            border-radius: inherit;
        }

        .tips-card {
            margin: 0 26px 26px;
            padding: 20px 22px;
            border-radius: 22px;
            background: linear-gradient(135deg, #ecfdf5 0%, #f0fdf4 100%);
            border: 1px solid rgba(16, 185, 129, 0.28);
        }

        .tips-card h2 {
            margin: 0 0 14px;
            color: #047857;
            font-size: 1.05rem;
            font-weight: 700;
        }

        .tips-card ul {
            margin: 0;
            padding-left: 1.2rem;
            color: #14532d;
        }

        .tips-card li + li {
            margin-top: 8px;
        }

        .actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            justify-content: center;
            padding: 0 26px 28px;
        }

        .action-link {
            min-width: 180px;
            padding: 14px 18px;
            border-radius: 14px;
            text-decoration: none;
            text-align: center;
            font-weight: 700;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .action-link:hover {
            transform: translateY(-2px);
        }

        .action-link.secondary {
            background: #fff;
            color: var(--primary);
            border: 1px solid rgba(37, 99, 235, 0.28);
        }

        .action-link.primary {
            background: linear-gradient(135deg, var(--primary) 0%, #1d4ed8 100%);
            color: #fff;
        }

        .action-link.success {
            background: linear-gradient(135deg, var(--success) 0%, #059669 100%);
            color: #fff;
        }

        @@media (max-width: 768px) {
            .hero {
                padding: 28px 18px 76px;
            }

            .hero h1 {
                font-size: 1.55rem;
            }

            .stats-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
                padding: 0 18px 18px;
            }

            .analysis-section,
            .tips-card,
            .actions {
                margin-left: 18px;
                margin-right: 18px;
                padding-left: 0;
                padding-right: 0;
            }
        }

        @@media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .actions {
                flex-direction: column;
            }

            .action-link {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="result-shell">
        <div class="result-card">
            <div class="hero">
                <h1>@Model.ExamTitle</h1>
                <p><i class="far fa-calendar me-2"></i>@Model.CompletedAt.ToString("HH:mm, dd/MM/yyyy")</p>
            </div>

            <div class="score-panel">
                <div class="score-title">@L("EstimatedReadingScore")</div>
                <div class="score-value">@Model.Score</div>
                <div class="score-total">/ 495</div>
            </div>

            <div class="stats-grid">
                <div class="stat-item">
                    <i class="fas fa-stopwatch text-primary"></i>
                    <span class="value">@timeFormatted</span>
                    <span class="label">@L("ExamTimeSpent")</span>
                </div>
                <div class="stat-item">
                    <i class="fas fa-check-circle text-success"></i>
                    <span class="value">@Model.CorrectCount</span>
                    <span class="label">@L("CorrectAnswersLabel")</span>
                </div>
                <div class="stat-item">
                    <i class="fas fa-times-circle text-danger"></i>
                    <span class="value">@Model.IncorrectCount</span>
                    <span class="label">@L("IncorrectAnswersLabel")</span>
                </div>
                <div class="stat-item">
                    <i class="fas fa-minus-circle text-secondary"></i>
                    <span class="value">@Model.SkippedCount</span>
                    <span class="label">@L("SkippedAnswersLabel")</span>
                </div>
            </div>

            <div class="analysis-section">
                <div class="section-title">
                    <i class="fas fa-chart-column text-primary"></i>
                    <span>@L("DetailedSectionAnalysis")</span>
                </div>

                @foreach (var part in partResults)
                {
                    <div class="part-card">
                        <div class="part-header">
                            <span>@part.Label</span>
                            <span>@part.Result.Correct/@part.Result.Total (@part.Result.Percentage%)</span>
                        </div>
                        <div class="part-progress">
                            <span style="width:@part.Result.Percentage%; background:@part.Color;"></span>
                        </div>
                    </div>
                }
            </div>

            <div class="tips-card">
                <h2><i class="fas fa-lightbulb me-2"></i>@L("ImprovementTipsTitle")</h2>
                <ul>
                    <li>@L("ImprovementTipKeepStrengths")</li>
                    <li>@L("ImprovementTipWeakestPart", weakestPart.Label)</li>
                    <li>@L("ImprovementTipPracticeMore")</li>
                </ul>
            </div>

            <div class="actions">
                <a href="/Exam/List" class="action-link secondary">
                    <i class="fas fa-arrow-left me-2"></i>@L("ExamLibrary")
                </a>
                <a href="/Exam/Start/@Model.ExamId" class="action-link primary">
                    <i class="fas fa-redo me-2"></i>@L("RetryExam")
                </a>
                <a href="/Home/Dashboard" class="action-link success">
                    <i class="fas fa-house me-2"></i>@L("DashboardPage")
                </a>
            </div>
        </div>
    </div>
</body>
</html>
