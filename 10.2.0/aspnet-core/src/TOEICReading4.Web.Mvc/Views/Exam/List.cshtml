@using TOEICReading4.Web.Models.Exam
@using TOEICReading4.Web.Startup
@model IReadOnlyList<ExamListItemViewModel>
@{
    ViewBag.Title = L("ExamLibraryPageTitle");
    ViewBag.CurrentPageName = PageNames.ExamLibrary;
}

@section Styles {
    <style>
        .library-page {
            gap: 1.35rem;
        }

        .library-toolbar {
            display: flex;
            gap: 0.85rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .library-search {
            flex: 1 1 320px;
        }

        .exam-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1rem;
        }

        .exam-card {
            display: flex;
            flex-direction: column;
            min-height: 100%;
            border-radius: 26px;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(255, 214, 232, 0.96);
            box-shadow: var(--shadow-soft);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .exam-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
        }

        .exam-card-banner {
            padding: 1rem 1.1rem;
            color: #fff;
            background: linear-gradient(135deg, var(--rose-500), #ff96c7);
            position: relative;
        }

        .exam-card-banner.completed {
            background: linear-gradient(135deg, #ff8ebd, #da6ca2);
        }

        .exam-card-banner i.banner-icon {
            position: absolute;
            top: 0.85rem;
            right: 1rem;
            font-size: 2.3rem;
            opacity: 0.18;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.38rem 0.72rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.18);
            font-size: 0.78rem;
            font-weight: 800;
            margin-bottom: 0.8rem;
        }

        .exam-card-body {
            padding: 1.15rem;
            display: flex;
            flex-direction: column;
            gap: 0.9rem;
            flex: 1;
        }

        .exam-category {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.42rem 0.78rem;
            border-radius: 999px;
            background: rgba(255, 240, 247, 0.9);
            color: var(--rose-700);
            font-size: 0.8rem;
            font-weight: 800;
            align-self: flex-start;
        }

        .exam-title {
            margin: 0;
            font-size: 1.12rem;
            font-weight: 800;
        }

        .exam-meta {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .exam-meta strong {
            display: block;
            margin-bottom: 0.2rem;
            color: var(--text-900);
        }

        .exam-meta span {
            color: var(--text-600);
            font-weight: 700;
        }

        .attempt-box {
            border-radius: 18px;
            background: rgba(255, 248, 251, 0.85);
            border: 1px solid rgba(255, 221, 235, 0.98);
            padding: 0.95rem;
        }

        .card-actions {
            display: flex;
            gap: 0.7rem;
            margin-top: auto;
            flex-wrap: wrap;
        }

        .card-actions a {
            flex: 1;
            min-width: 138px;
            text-align: center;
            padding: 0.78rem 1rem;
            border-radius: 16px;
            text-decoration: none;
            font-weight: 800;
        }

        .btn-preview {
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(255, 188, 214, 0.58);
            color: var(--text-700);
        }

        .btn-start,
        .btn-result {
            color: #fff;
            background: linear-gradient(135deg, var(--rose-500), #ff95c6);
        }
    </style>
}

<div class="app-page library-page">
    <section class="app-hero">
        <div class="app-hero-content">
            <div>
                <div class="app-hero-badges">
                    <span class="app-chip"><i class="fas fa-book-open"></i> @L("ExamLibrary")</span>
                </div>
                <h1>@L("ExamLibrary")</h1>
                <p>@L("ExamLibraryDescription")</p>
            </div>

            <div class="app-actions">
                <a href="/Home/Index" class="btn btn-primary">
                    <i class="fas fa-cloud-upload-alt me-2"></i>@L("UploadExam")
                </a>
            </div>
        </div>
    </section>

    <section class="app-panel">
        <div class="library-toolbar">
            <input type="text" class="form-control library-search" id="searchExam" placeholder="@L("SearchExamPlaceholder")" />
            <span class="app-chip"><i class="fas fa-layer-group"></i>@(Model?.Count ?? 0) exams</span>
        </div>
    </section>

    @if (Model == null || Model.Count == 0)
    {
        <div class="app-empty-state">
            <i class="fas fa-inbox"></i>
            <h3>@L("NoExamsYetTitle")</h3>
            <p>@L("NoExamsYetDescription")</p>
            <a href="/Home/Index" class="btn btn-primary mt-3">
                <i class="fas fa-upload me-2"></i>@L("UploadExam")
            </a>
        </div>
    }
    else
    {
        <div class="exam-grid" id="examGrid">
            @foreach (var item in Model)
            {
                var exam = item.Exam;
                var hasAttempt = item.HasAttempt;
                var questionCount = exam.Questions?.Count ?? 0;
                <div class="exam-card">
                    <div class="exam-card-banner @(hasAttempt ? "completed" : string.Empty)">
                        <span class="status-pill">
                            <i class="fas @(hasAttempt ? "fa-check-circle" : "fa-star")"></i>
                            @(hasAttempt ? L("CompletedStatus") : L("NewStatus"))
                        </span>
                        <h3 class="exam-title text-white">@exam.Title</h3>
                        <i class="fas @(hasAttempt ? "fa-chart-bar" : "fa-file-alt") banner-icon"></i>
                    </div>
                    <div class="exam-card-body">
                        <span class="exam-category">
                            <i class="fas fa-feather-alt"></i>@L("ToeicReadingCategory")
                        </span>

                        <div class="exam-meta">
                            <div>
                                <strong>@L("DurationLabel")</strong>
                                <span>@exam.DurationMinutes @L("MinutesShort")</span>
                            </div>
                            <div>
                                <strong>@L("QuestionCountLabel")</strong>
                                <span>@questionCount</span>
                            </div>
                        </div>

                        @if (hasAttempt)
                        {
                            <div class="attempt-box">
                                <div><strong>@L("LatestResultLabel"):</strong> @(item.LatestScore ?? 0)/495</div>
                                @if (item.LastCompletedAt.HasValue)
                                {
                                    <div class="text-muted mt-1">@item.LastCompletedAt.Value.ToString("HH:mm dd/MM/yyyy")</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="attempt-box">
                                <div><strong>@L("ReadyToStartLabel")</strong></div>
                                <div class="text-muted mt-1">@L("ReadyToStartDescription")</div>
                            </div>
                        }

                        <div class="card-actions">
                            <a class="btn-preview" href="/Exam/Preview/@exam.Id">
                                <i class="fas fa-eye me-2"></i>@L("PreviewExam")
                            </a>
                            @if (hasAttempt && item.LatestAttemptId.HasValue)
                            {
                                <a class="btn-result" href="/Exam/Result/@item.LatestAttemptId.Value">
                                    <i class="fas fa-chart-bar me-2"></i>@L("ViewResult")
                                </a>
                            }
                            else
                            {
                                <a class="btn-start" href="/Exam/Start/@exam.Id">
                                    <i class="fas fa-play me-2"></i>@L("StartExam")
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        $(function () {
            $('#searchExam').on('input', function () {
                var searchTerm = $(this).val().toLowerCase();

                $('#examGrid .exam-card').each(function () {
                    var title = $(this).find('.exam-title').text().toLowerCase();
                    $(this).toggle(title.indexOf(searchTerm) >= 0);
                });
            });
        });
    </script>
}
