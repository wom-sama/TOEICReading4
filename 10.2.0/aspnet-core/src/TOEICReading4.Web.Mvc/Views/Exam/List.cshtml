@using TOEICReading4.Web.Models.Exam
@model IReadOnlyList<ExamListItemViewModel>
@{
    ViewBag.Title = L("ExamLibraryPageTitle");
}

@section Styles {
    <style>
        :root {
            --primary: #2563eb;
            --success: #10b981;
            --warning: #f59e0b;
            --surface: #ffffff;
            --surface-alt: #f8fafc;
            --text: #111827;
            --muted: #64748b;
            --border: #dbe3ef;
            --shadow: 0 16px 36px rgba(15, 23, 42, 0.08);
        }

        .library-shell {
            padding: 2rem 0 3rem;
        }

        .library-hero {
            padding: 2.4rem 2rem;
            border-radius: 24px;
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 62%, #2563eb 100%);
            color: #fff;
            box-shadow: var(--shadow);
            margin-bottom: 1.5rem;
        }

        .library-hero h1 {
            margin: 0 0 8px;
            font-weight: 700;
        }

        .library-hero p {
            margin: 0;
            color: rgba(255, 255, 255, 0.82);
        }

        .library-toolbar {
            background: var(--surface);
            border: 1px solid rgba(148, 163, 184, 0.18);
            border-radius: 18px;
            padding: 1rem;
            box-shadow: var(--shadow);
            margin-bottom: 1.5rem;
        }

        .toolbar-input {
            border-radius: 14px;
            border: 1px solid var(--border);
            padding: 0.85rem 1rem;
        }

        .toolbar-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.08);
        }

        .exam-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1rem;
        }

        .exam-card {
            display: flex;
            flex-direction: column;
            min-height: 100%;
            border-radius: 22px;
            background: var(--surface);
            border: 1px solid rgba(148, 163, 184, 0.18);
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .exam-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 24px 44px rgba(15, 23, 42, 0.12);
        }

        .exam-card-banner {
            padding: 1rem 1.1rem 0.9rem;
            position: relative;
            color: #fff;
            min-height: 112px;
            background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
        }

        .exam-card-banner.completed {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
        }

        .exam-card-banner i {
            position: absolute;
            right: 1rem;
            top: 0.8rem;
            font-size: 2.6rem;
            opacity: 0.18;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.42rem 0.75rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.16);
            font-size: 0.76rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .exam-card-body {
            padding: 1.1rem;
            display: flex;
            flex-direction: column;
            gap: 0.9rem;
            flex: 1;
        }

        .exam-category {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.8rem;
            color: var(--primary);
            background: rgba(37, 99, 235, 0.08);
            border-radius: 999px;
            padding: 0.38rem 0.72rem;
            font-weight: 700;
            align-self: flex-start;
        }

        .exam-title {
            font-size: 1.05rem;
            font-weight: 700;
            margin: 0;
            color: var(--text);
        }

        .exam-meta {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
            color: var(--muted);
            font-size: 0.88rem;
        }

        .exam-meta strong {
            display: block;
            color: var(--text);
            margin-bottom: 4px;
        }

        .attempt-box {
            border-radius: 16px;
            background: linear-gradient(135deg, #eff6ff 0%, #f8fafc 100%);
            border: 1px solid var(--border);
            padding: 0.9rem;
        }

        .attempt-box strong {
            color: var(--text);
        }

        .card-actions {
            display: flex;
            gap: 10px;
            margin-top: auto;
        }

        .card-actions a {
            flex: 1;
            text-align: center;
            border-radius: 14px;
            padding: 0.75rem 0.9rem;
            font-weight: 700;
            text-decoration: none;
            transition: transform 0.2s ease;
        }

        .card-actions a:hover {
            transform: translateY(-1px);
        }

        .btn-preview {
            border: 1px solid rgba(100, 116, 139, 0.25);
            color: var(--text);
            background: #fff;
        }

        .btn-start {
            color: #fff;
            background: linear-gradient(135deg, var(--primary) 0%, #1d4ed8 100%);
        }

        .btn-result {
            color: #fff;
            background: linear-gradient(135deg, var(--success) 0%, #059669 100%);
        }

        .empty-state {
            padding: 3rem 1.5rem;
            border-radius: 22px;
            background: var(--surface);
            border: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: var(--shadow);
            text-align: center;
        }

        .empty-state i {
            font-size: 3.2rem;
            color: #cbd5e1;
            margin-bottom: 1rem;
        }

        @@media (max-width: 576px) {
            .library-hero {
                padding: 1.8rem 1.25rem;
            }

            .exam-meta {
                grid-template-columns: 1fr;
            }

            .card-actions {
                flex-direction: column;
            }
        }
    </style>
}

<div class="container-fluid px-3 px-md-4 library-shell">
    <div class="library-hero">
        <h1><i class="fas fa-book-open me-2"></i>@L("ExamLibrary")</h1>
        <p>@L("ExamLibraryDescription")</p>
    </div>

    <div class="library-toolbar">
        <input type="text" class="form-control toolbar-input" id="searchExam" placeholder="@L("SearchExamPlaceholder")" />
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-inbox"></i>
            <h3>@L("NoExamsYetTitle")</h3>
            <p>@L("NoExamsYetDescription")</p>
            <a href="/Home/Index" class="btn btn-primary mt-3">
                <i class="fas fa-upload me-2"></i>@L("UploadExam")
            </a>
        </div>
    }
    else
    {
        <div class="exam-grid" id="examGrid">
            @foreach (var item in Model)
            {
                var exam = item.Exam;
                var hasAttempt = item.HasAttempt;
                var questionCount = exam.Questions?.Count ?? 0;
                <div class="exam-card">
                    <div class="exam-card-banner @(hasAttempt ? "completed" : string.Empty)">
                        <span class="status-pill">
                            <i class="fas @(hasAttempt ? "fa-circle-check" : "fa-sparkles")"></i>
                            @(hasAttempt ? L("CompletedStatus") : L("NewStatus"))
                        </span>
                        <h3 class="exam-title text-white">@exam.Title</h3>
                        <i class="fas @(hasAttempt ? "fa-chart-line" : "fa-file-lines")"></i>
                    </div>
                    <div class="exam-card-body">
                        <span class="exam-category">
                            <i class="fas fa-layer-group"></i>@L("ToeicReadingCategory")
                        </span>

                        <div class="exam-meta">
                            <div>
                                <strong>@L("DurationLabel")</strong>
                                <span>@exam.DurationMinutes @L("MinutesShort")</span>
                            </div>
                            <div>
                                <strong>@L("QuestionCountLabel")</strong>
                                <span>@questionCount</span>
                            </div>
                        </div>

                        @if (hasAttempt)
                        {
                            <div class="attempt-box">
                                <div><strong>@L("LatestResultLabel"):</strong> @(item.LatestScore ?? 0)/495</div>
                                @if (item.LastCompletedAt.HasValue)
                                {
                                    <div class="text-muted mt-1">@item.LastCompletedAt.Value.ToString("HH:mm dd/MM/yyyy")</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="attempt-box">
                                <div><strong>@L("ReadyToStartLabel")</strong></div>
                                <div class="text-muted mt-1">@L("ReadyToStartDescription")</div>
                            </div>
                        }

                        <div class="card-actions">
                            <a class="btn-preview" href="/Exam/Preview/@exam.Id">
                                <i class="fas fa-eye me-2"></i>@L("PreviewExam")
                            </a>
                            @if (hasAttempt && item.LatestAttemptId.HasValue)
                            {
                                <a class="btn-result" href="/Exam/Result/@item.LatestAttemptId.Value">
                                    <i class="fas fa-chart-column me-2"></i>@L("ViewResult")
                                </a>
                            }
                            else
                            {
                                <a class="btn-start" href="/Exam/Start/@exam.Id">
                                    <i class="fas fa-play me-2"></i>@L("StartExam")
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        $(function () {
            $('#searchExam').on('input', function () {
                var searchTerm = $(this).val().toLowerCase();

                $('#examGrid .exam-card').each(function () {
                    var title = $(this).find('.exam-title').text().toLowerCase();
                    $(this).toggle(title.indexOf(searchTerm) >= 0);
                });
            });
        });
    </script>
}
