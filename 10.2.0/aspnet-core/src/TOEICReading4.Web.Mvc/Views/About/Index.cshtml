@using TOEICReading4.Web.Startup
@{
    ViewBag.CurrentPageName = PageNames.About;
    ViewBag.Title = L("About");
}

<div class="app-page">
    <section class="app-hero">
        <div class="app-hero-content">
            <div>
                <div class="app-hero-badges">
                    <span class="app-chip"><i class="fas fa-heart"></i>@L("About")</span>
                </div>
                <h1>@L("About")</h1>
            </div>
        </div>
    </section>

    <section class="app-panel">
        <div class="app-panel-header">
            <div>
                <h2>TOEICReading4</h2>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-lg-4">
                <div class="app-stat-card h-100">
                    <div class="app-stat-icon"><i class="fas fa-cloud-upload-alt"></i></div>
                    <div>
                        <strong>@L("UploadExam")</strong>
                        <span>@L("UploadExamDescription")</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="app-stat-card h-100">
                    <div class="app-stat-icon"><i class="fas fa-play-circle"></i></div>
                    <div>
                        <strong>@L("StartExam")</strong>
                        <span>@L("ToeicReadingPartsLabel")</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="app-stat-card h-100">
                    <div class="app-stat-icon"><i class="fas fa-chart-line"></i></div>
                    <div>
                        <strong>@L("ViewResult")</strong>
                        <span>@L("DetailedSectionAnalysis")</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
